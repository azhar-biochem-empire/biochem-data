body{
margin:0; 
font-family:Arial, 
sans-serif;
background:#f4f7f9;
text-align:center; 
}
header{
background:#064663;
color:white;
padding:50px 20px; 
}
h1{
font-size:45px;
margin:0;
}
h2{ 
font-weight:normal; 
margin-top:10px;
}
.container{
margin-top:50px; 
} 
.card{
background:white; 
width:300px;
margin:20px auto; 
padding:25px;
border-radius:15px; 
box-shadow:0 5px 15px #bbb;
transition:.3s;
} 
.card:hover{ 
transform:scale(1.05); 
} 
a{
text-decoration:none; 
color:#064663; 
font-size:25px;
font-weight:bold; 
} 
.description{
margin:50px auto;
max-width:700px; 
font-size:20px;
color:#333; 
line-height:1.6; 
}
